
menu "STCP Configuration"

config STCP
    bool "Enable STCP LTE transport"
    default y
    depends on NET_SOCKETS
    help
      Enable STCP LTE transport.

config MQTT_LIB_STCP
    bool "STCP support for socket MQTT Library"
    default y
    depends on STCP && MQTT_LIB
    help
      Enable STCP support for socket MQTT Library

config STCP_DEBUG
    bool "Enable STCP debug"
    default y
    depends on STCP   # esimerkki: riippuvuudet kernelistä
    help
      Enable STCP debugs.

config STCP_DEBUG_LATENCY
    bool "Enable STCP latency debug"
    default y
    depends on STCP_DEBUG   # esimerkki: riippuvuudet kernelistä
    help
      Enable STCP latency debugs.

config STCP_WATCHDOG_ENABLE
    bool "Enable STCP watchdog"
    default y
    depends on STCP
    help
      Enable STCP watchdog thread that monitors
      STCP activity and network health.

config STCP_WATCHDOG_MAX_TIMEOUT
    int "Watchdog timeout in seconds"
    default 300
    range 30 36000
    depends on STCP_WATCHDOG_ENABLE
    help
      Maximum allowed inactivity time before
      the watchdog triggers a modem reset.

config STCP_WATCHDOG_CHECK_INTERVAL
    int "Watchdog check interval in seconds"
    default 15
    range 5 36000
    depends on STCP_WATCHDOG_ENABLE
    help
      Interval between watchdog health checks.

config STCP_SELFTEST
    bool "Enable STCP self-test"
    default y
    depends on STCP
    help
      Enable STCP self-test support.

config STCP_AES_BYPASS
    bool "Enable STCP AES bypass"
    default n
    depends on STCP   # esimerkki: riippuvuudet kernelistä
    help
      Bypass AES enc/decryption for development purposes.

config STCP_CONNECT_TO_HOST
    string "STCP Connect to hostname"
    default "lja.fi"
    depends on STCP
    help
      STCP Remote endpoint hostname.

config STCP_CONNECT_TO_PORT
    string "STCP Connect to tcp port"
    default "7777"
    depends on STCP
    help
      STCP Remote endpoint tcp port.

config STCP_LTE_APN_NAME
    string "The APN name to connect."
    default "internet"
    depends on STCP
    help
      The APN name to use to connect.

      Ask from your ISP what is the right APN
      name to use.


endmenu
