menuconfig STCP
    bool "STCP socket offload (C carrier port)"
    depends on NET_SOCKETS
    select NET_SOCKETS_OFFLOAD
    default n

if STCP

config STCP_SOCKET_PRIORITY
    int "Socket provider priority"
    default 20

config STCP_MAX_SOCKETS
    int "Maximum STCP sockets"
    default 16
    range 2 64

config STCP_IO_TIMEOUT_MS
    int "Blocking carrier I/O timeout (milliseconds)"
    default 5000
    range 1 60000

config STCP_LOG_LEVEL
    int "STCP log level"
    default 3
    range 0 4

endif
